{
  "name": "stream-hub",
  "version": "0.5.2",
  "description": "A desktop browser for streaming sites, with bookmarks, automatic watch-progress tracking, and ad-blocking.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node test/e2e.js",
    "dist": "electron-builder"
  },
  "keywords": [
    "electron",
    "streaming",
    "media",
    "desktop",
    "webview"
  ],
  "author": "Joshua Irvine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jbi2109/stream-hub.git"
  },
  "type": "commonjs",
  "build": {
    "appId": "com.jbi2109.streamhub",
    "productName": "Stream Hub",
    "files": [
      "**/*",
      "!test",
      "!docs",
      "!.github",
      "!.plans",
      "!**/*.md",
      "!launch.bat",
      "!dist"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "publish": {
      "provider": "github",
      "owner": "jbi2109",
      "repo": "stream-hub",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.18.1",
    "electron-updater": "^6.3.0"
  }
}
